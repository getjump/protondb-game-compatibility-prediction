# ============================================================================
# ProtonDB Recommended Settings — Environment Configuration
# RTX 4080 Super (16GB VRAM) + Qwen 3.5 9B (local via ollama/llama.cpp)
# ============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────
# Backend: "openai" (default), "openrouter", or "claude-cli"
# LLM_BACKEND=openrouter
# LLM_BACKEND=claude-cli
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=not-needed
MODEL=qwen3.5:latest

# ── OpenRouter (when LLM_BACKEND=openrouter) ─────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# MODEL=anthropic/claude-sonnet-4  # or google/gemini-2.5-flash, etc.

# ── LLM Tuning ───────────────────────────────────────────────────────
# temperature=0 for deterministic structured output tasks
LLM_TEMPERATURE=0.0
# Max output tokens per LLM call (GPU/CPU norm ~100 tokens, extract ~2000)
LLM_MAX_TOKENS=4096
# Retries on failure (local model: lower is better, won't magically fix itself)
LLM_MAX_RETRIES=3
# Concurrent requests (local: 1, cloud: 10+)
LLM_CONCURRENCY=1

# ── LLM Batch Sizes (local) ─────────────────────────────────────────
# How many items per single LLM call. Larger = faster but more VRAM.
# RTX 4080S (16GB) with 9B model: 5-8 items/batch is safe.
GPU_NORM_BATCH_LOCAL=5
CPU_NORM_BATCH_LOCAL=5
LAUNCH_OPT_BATCH_LOCAL=3
EXTRACT_BATCH_LOCAL=3

# ── LLM Batch Sizes (cloud, used when base_url is not localhost) ────
# GPU_NORM_BATCH_CLOUD=30
# CPU_NORM_BATCH_CLOUD=30
# LAUNCH_OPT_BATCH_CLOUD=15
# EXTRACT_BATCH_CLOUD=10

# ── Enrichment Rate Limits (requests/second) ────────────────────────
STEAM_RATE_LIMIT=0.6
PROTONDB_RATE_LIMIT=3.0
PCGW_RATE_LIMIT=2.0

# ── Paths ────────────────────────────────────────────────────────────
# PROTONDB_DB_PATH=./data/protondb.db
# PROTONDB_MODEL_PATH=./data/model.pkl
# PROTONDB_EMBEDDINGS_PATH=./data/embeddings.npz
# PROTONDB_PORT=8080
